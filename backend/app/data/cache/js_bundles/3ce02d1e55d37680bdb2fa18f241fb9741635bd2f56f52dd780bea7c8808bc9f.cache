(function() {
    if(window.cmg_ketch) {
        branchio();
    } else {
        document.addEventListener('cmg-ketch', branchio);
    }
    function branchio() {
        let dataset = document.querySelector("meta[property='branchio']")?.dataset;
        if (dataset !== undefined) {
            (function (b, r, a, n, c, h, _, s, d, k) {
                if (!b[n] || !b[n]._q) {
                    for (; s < _.length;) c(h, _[s++]);
                    d = r.createElement(a);
                    d.async = 1;
                    d.src = dataset.branchioUrl;
                    k = r.getElementsByTagName(a)[0];
                    k.parentNode.insertBefore(d, k);
                    b[n] = h
                }
            })(window, document, "script", "branch", function (b, r) {
                b[r] = function () {
                    b._q.push([r, arguments])
                }
            }, {
                _q: [],
                _v: 1
            }, "addListener applyCode autoAppIndex banner closeBanner closeJourney creditHistory credits data deepview deepviewCta first getCode init link logout redeem referrals removeListener sendSMS setBranchViewData setIdentity track validateCode trackCommerceEvent logEvent disableTracking".split(" "), 0);
            branch.init(dataset.branchioAppkey);
        }
    };
})();
(function () {
    if(window.cmg_ketch) {
        adobeDatalayer();
    } else {
        document.addEventListener('cmg-ketch', adobeDatalayer);
    }
    function adobeDatalayer() {

        var dataset = document.querySelector("meta[property='adobedatalayer']")?.dataset;
        if (dataset !== undefined) {
            window.adobeDataLayer = window.adobeDataLayer || [];
            adobeDataLayer.push({
                page: JSON.parse(document.querySelector('body').attributes['data-adobe-json'].value.replace(/&#34;/g, '"')),
                event: 'cmp:show',
                eventInfo: {
                    path: 'page.' + dataset.id // this is incorrect
                }
            });
        }
    }
})();
(function() {
    function adobeAnalyticsHandlers() {
        const waitForChipotleDataLayer = () => {
            let retries = 0;
            const maxRetries = 3;
            const intervalId = setInterval(() => {
                const chipotleDataLayer = window.ChipotleDataLayer;
                if (chipotleDataLayer && chipotleDataLayer.isDataLayerEnabled()) {
                    let anchorElements = document.querySelectorAll("a.aa-click-enabled");
                    anchorElements.forEach(el => {
                        el.addEventListener('click',
                          (event) => chipotleDataLayer.addClickTrackingToDataLayer(event.currentTarget));
                    });
                    clearInterval(intervalId);
                } else if (++retries >= maxRetries) {
                    clearInterval(intervalId);
                }
            }, 200);
        };
        waitForChipotleDataLayer();
    }
    if(window.cmg_ketch) {
        adobeAnalyticsHandlers();
    } else {
        document.addEventListener('cmg-ketch', adobeAnalyticsHandlers);
    }
})();
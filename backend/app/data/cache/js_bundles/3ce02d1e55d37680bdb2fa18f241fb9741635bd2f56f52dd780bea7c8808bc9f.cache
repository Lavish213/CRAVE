// chipotle-target-prehiding
(function() {

    function unhidePage() {
        if( document.querySelector("style#alloy-prehiding") ) {
            console.warn("TARGET PREHIDING: Timed out, unveiling page now.");
            document.querySelector("style#alloy-prehiding").remove();
        }
    }

    const $el = document.querySelector("#aem-target-prehiding");
    if( !$el ) {
        return;
    }
    let duration = $el.dataset?.hideDuration || 2500;
    let hideEvent = $el.dataset?.hideEvent;
    setTimeout(unhidePage, duration);
    if( hideEvent ) {
        window.addEventListener('hideEvent', unhidePage );
    }

    // show hero videos after unhiding
    let isVisible = function(el) {
        return !!(el.offsetWidth || el.offsetHeight || (el.getClientRects() && el.getClientRects().length));
    };
    var showHeroVideos = function() {
        var videos = document.querySelectorAll(".aem-hero video");
        if (videos) {
            Array.from(videos).map(video => {
                if (isVisible(video)) {
                    Array.from(video.children).map(child => {
                        if (child.tagName === "SOURCE" && !child.src) {
                            child.src = child.dataset.src;
                            video.load();
                        }
                    });
                }
            })
        }
    };
    let targetNode = document.getElementById("aem-target-prehiding");
    if( targetNode !== null ) {
        const config = {
            attributes: false,
            childList: true,
            subtree: false
        };
        const callback = (mutationList, observer) => {
            for (let mutation of mutationList) {
                if (mutation.removedNodes.length && mutation.removedNodes[0].id === "alloy-prehiding") {
                    observer.disconnect();
                    window.dispatchEvent(new Event('cmg-target-prehiding-unveiled'));
                    setTimeout(showHeroVideos, 250);
                }
            }
        };
        let observer = new MutationObserver(callback);
        observer.observe(targetNode, config);
    }
})();

source:"/* pnraLaunch:Enable */\nif (location.search.indexOf('utm') > -1){\n\t_satellite.setVar('findPage', 'External_campaign');\n} else if (location.search.indexOf('intcmp') > -1) {\n\t_satellite.setVar('findPage', 'Internal_campaign');\n} else  {\n\t_satellite.setVar('findPage', 'Non_Marketing_Page_Load');\n}\n\nif (window.location.href.indexOf('mobilePickupOrdering') > -1 || sessionStorage.getItem('mobilePickupOrdering')==='seen') {\n\tsessionStorage.setItem('mobilePickupOrdering','seen');\n}\n\n\npnraLaunch = {\n  \n   pageView: function () {\n     //now that we have a page view, store the last click's page finding method into findPage for this page's page finding method  \n     _satellite.setVar('findPage',_satellite.getVar('findPage_temp'));\n\n     // Temporary fix for analytics; page title update should be in ui project after 10/2/2019 release.\n     if (location.pathname.indexOf('app/confirmation') > -1) {\n       document.title = 'Order Confirmation';\n     } \n  \n     if (typeof s !== 'undefined') {\n       s.clearVars();\n       s.pageName = undefined;\n     }\n     \n     _satellite.track(\"page view\");  //probably unused but no good way to search for references\n     _satellite.track(\"send pixel page view\");\n     _satellite.track(\"target trigger view\");\n\n     if(window.location.href.indexOf('/checkout.html') > -1) {\n       //_satellite.track(\"refreshCache\");\n     }\n     \n     // Dispatch pnraPageView event\n     //document.body.dispatchEvent(new CustomEvent('pnraPageView'));\n     \n },\n  subscriptionSuccess: function () {\n     setTimeout(() => {_satellite.track(\"aa track subscription success\") }, 500);\n  },\n  \n  subscriptionCancel: function () {\n     _satellite.track(\"aa track subscription cancel\");\n  },\n  subscriptionReenroll: function () {\n     _satellite.track(\"aa track subscription reenroll\");\n  },\n  addCreditCardSuccess: function () {\n     _satellite.track(\"aa add credit card\");\n  },\n  updateCreditCardSuccess: function () {\n     _satellite.track(\"aa update credit card\");\n  },\n  \n  trackInternalSearch: function (params) {\n     _satellite.track(\"aa track internal search\", {\n       input: params.input,\n       type: params.type,\n       resultsCount: params.resultsCount,\n     });\n  },\n  \n  trackIdentifyPhoneLookup: function (params) {\n     _satellite.track(\"aa qr scan phone lookup\", {\n       identificationSuccessful: params.identificationSuccessful,\n     });\n  },\n  trackIdentifyCustomerArrival: function (params) {\n     _satellite.track(\"aa qr scan customer arrival\", {\n       identificationSuccessful: params.identificationSuccessful,\n     });\n  },\n\n};\n\n// Dispatch Event in IE11-safe manner\n\nvar event;\nif (typeof(Event) === 'function') {\n    event = new Event('pnraLaunchLoaded');\n} else{\n    event = document.createEvent('Event');\n    event.initEvent('pnraLaunchLoaded', true, true);\n}\nwindow.dispatchEvent(event);\n\n\n//Add a couple Global Styles \n(function(){\n\tif (!document.querySelector('#atGlobalStyles')) {\n\t\tvar styleSheet =  \t' @media (min-width: 901px) { ' +\n\t\t\t\t\t\t\t'\t.at-mob { display:none !important } .at-dt { display:inline !important } ' +\n\t\t\t\t\t\t\t' } ' +\n\t\t\t\t\t\t\t' @media (max-width: 900px) { ' +\n\t\t\t\t\t\t\t'\t.at-mob { display:inline !important } .at-dt { display:none !important } ' +\n\t\t\t\t\t\t\t' } '\n\t\tvar styleElement = document.createElement('style');\n\t\tstyleElement.type = 'text/css';\n\t\tstyleElement.id = 'atGlobalStyles'\n\t\tstyleElement.innerHTML = styleSheet;\n\t\tdocument.head.appendChild(styleElement);\n\t}\n})();\n\n//Add commonly used functions\nwindow.pnraTarget = window.pnraTarget || {};\nwindow.pnraTarget.fn = window.pnraTarget.fn || {};\n\n//setup lists of productIds for each upsell type\n//this usually fails to fill them, because this rule runs before the Target Activities that set these values has run. But need this here in case the activity doesn't load so theat they are at least defined\nwindow.atSingleBagelsProductList = (pnraTarget.upsells && pnraTarget.upsells.atSingleBagelsProductList) ? pnraTarget.upsells.atSingleBagelsProductList : [];\nwindow.atEntreesProductList = (pnraTarget.upsells && pnraTarget.upsells.atEntreesProductList) ? pnraTarget.upsells.atEntreesProductList : [];\nwindow.atBreakfastEntreeProductList = (pnraTarget.upsells && pnraTarget.upsells.atBreakfastEntreeProductList) ? pnraTarget.upsells.atBreakfastEntreeProductList : [];\nwindow.atMyPTreats = (pnraTarget.upsells && pnraTarget.upsells.MyPTreats) ? pnraTarget.upsells.MyPTreats : [];\nwindow.atUSCItems = (pnraTarget.upsells && pnraTarget.upsells.USCItems) ? pnraTarget.upsells.USCItems : [];\nwindow.atBOGO5Items = (pnraTarget.upsells && pnraTarget.upsells.atBOGO5Items) ? pnraTarget.upsells.atBOGO5Items : [];\nwindow.atAllBeverageItems = (pnraTarget.upsells && pnraTarget.upsells.atAllBeverageItems) ? pnraTarget.upsells.atAllBeverageItems : [];\n\n//isAnnualSubscriber\nwindow.pnraTarget.fn.isAnnualSubscriber = function() {\n\t//check Data Element\n\tif (_satellite.getVar('AA: Subscription Tier Type') == \"annual\") {\n\t\twindow.pnraTarget.isAnnualSubscriber = true;\n\t\twindow.pnraTarget.isCoffeeSubscriber = true;\n\t\treturn true;\n\t}\n\n\treturn false;\n};\n\n//isMonthlySubscriber\nwindow.pnraTarget.fn.isMonthlySubscriber = function() {\n\t//check Data Element\n\tif (_satellite.getVar('AA: Subscription Tier Type') == \"monthly\") {\n\t\twindow.pnraTarget.isMonthlySubscriber = true;\n\t\twindow.pnraTarget.isCoffeeSubscriber = true;\n\t\treturn true;\n\t}\n\n\treturn false;\n};\n\n//isExpiringSubscriber\nwindow.pnraTarget.fn.isExpiringSubscriber = function() {\n\t//check Data Element\n\tfor (var i=0; i<dataLayer.user.subscriptions.length; i++) {\n\t\tif (dataLayer.user.subscriptions[i].scope === 'CANCELLED_BUT_ACTIVE_RESUBSCRIBER') {\n\t\t\twindow.pnraTarget.isExpiringSubscriber = true;\n\t\t\treturn true;\n\t\t}\n\t}\n\treturn false;\n};\n\n//isCoffeeSubscriber\nwindow.pnraTarget.fn.isCoffeeSubScriber = function() {\n\t//check vue\n\tif (document.querySelector('[iw-app]')) {\n\t\ttry {\n\t\t\tiwApp = document.querySelector('[iw-app]');\n\t\t\tvue = iwApp.__vue__;\n\t\t\tisSubscriber = vue.$store.getters['user/isCoffeeSubscriber'];\n\t\t\tif (isSubscriber) { \n\t\t\t\twindow.pnraTarget.isCoffeeSubscriber = true;\n\t\t\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\t\t\treturn true;\n\t\t\t}\n\t\t} catch(e) {}\n\t}\n\n\t//check dataLayer\n\tif (dataLayer && dataLayer.user && dataLayer.user.isCoffeeSubscriber) {\n\t\twindow.pnraTarget.isCoffeeSubscriber = true;\n\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\treturn true;\n\t}\n\n\t//check QSParam\n\tif (window.location.search.indexOf('qasubscriber=true') > -1) {\n\t\twindow.pnraTarget.isCoffeeSubscriber = true;\n\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\treturn true;\n\t}\n\n\t//check window scoped variable\n\tif (window.pnraTarget.isCoffeeSubscriber===true) {\n\t\treturn true;\n\t}\n\n\treturn false;\n};\n\n//isLapsedSubscriber\nwindow.pnraTarget.fn.isLapsedSubscriber = function() {\n\t//check window scoped variable (set via AEP audience)\n\tif (window.pnraTarget.isLapsedSubscriber === true) {\n\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\treturn true;\n\t}\n\n\tif (dataLayer && dataLayer.user && dataLayer.user.subscriptions && dataLayer.user.subscriptions.length > 0) {\n\t\tfor (var i=0; i<dataLayer.user.subscriptions.length; i++) {\n\t\t\tif (dataLayer.user.subscriptions[i].scope === 'LAPSED_RESUBSCRIBER') {\n\t\t\t\twindow.pnraTarget.isLapsedSubscriber = true;\n\t\t\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t}\n\n\treturn false;\n};\n\n//isSignedIn\nwindow.pnraTarget.fn.isSignedIn = function() {\n\t//check dataLayer\n\tif (dataLayer && dataLayer.user && typeof dataLayer.user.customerId === 'number') {\n\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\treturn true;\n\t}\n\n\treturn false;\n};\n\n//isMyPaneraMember\nwindow.pnraTarget.fn.isMyPaneraMember = function() {\n\t//check dataLayer\n\tif (dataLayer && dataLayer.user && typeof dataLayer.user.customerId === 'number') {\n\t\twindow.pnraTarget.isMyPaneraMember = true;\n\t\treturn true;\n\t}\n\n\tif (window.pnraTarget.isMyPaneraMember===true) {\n\t\t//check window scoped variable (set via AEP audience)\n\t\treturn true;\n\t}\n\n\treturn false;\n};\n\n\n//eligiblePage - used for AppsFlyer, Modals, etc.\nwindow.pnraTarget.fn.eligiblePage = function(list) {\n\tif (list==='appsFlyer') {\n\t\tvar URLsToExclude = ['/new-era-at-panera', '/mobilePickupOrdering', '/inCafeOrdering', '/order-now', '/crunch-time', '/mypanera/', '/articles/', '/legal/', '/NTWRK', '/subscription', '/company-information', '/contactless-pickup.html', '/coffee-registration-flow.html', '/egift.html', '/gift-cards.html', '/cafe-locator.html', '/sign-up-with-mypanera.html', '/identify.html', '/panera-foundation', '/media.html', 'two-dollars-off-order.html', 'community-catering.html', 'earn-fifteen.html', 'holiday-catering.html', '/registration-flow.html', '/join-group-order', '/activeorder/', '/incentive-trip-winners' ]\n\t} else {\n\t\tvar URLsToExclude = ['/new-era-at-panera', '/mobilePickupOrdering', '/inCafeOrdering', '/order-now', '/crunch-time', '/mypanera/', '/articles/', '/legal/', '/NTWRK', '/subscription', '/company-information', '/contactless-pickup.html', '/coffee-registration-flow.html', '/egift.html', '/gift-cards.html', '/cafe-locator.html', '/sign-up-with-mypanera.html', '/identify.html', '/panera-foundation', '/media.html', 'two-dollars-off-order.html', 'community-catering.html', 'earn-fifteen.html', 'holiday-catering.html', '/wifi.html', '/forgot-mypanera-password.html', '/reset-mypanera-password.html', '/checkout.html', '/confirmation.html', '/cancel-your-panera-order.html', '/promo-ten-off-fifteen.html', '/covid-19.html', '/allergen-and-nutrition-information.html', '/cool-food-meals.html', '/online-promo-code.html', '/menu.html', '/join-group-order', '/delivery-guarantee-form.html', '/audible-on-us.html', '/incentive-trip-winners', '/rewards.html']\n\t}\n\n\tif (window.location.search.indexOf('isKiosk=true') > -1) {\n\t\treturn false;\n\t}\n\n\tfor (var i=0; i<URLsToExclude.length; i++) {\n\t\tif (window.location.pathname.indexOf(URLsToExclude[i]) > -1) {\n\t\t\treturn false;\n\t\t}\n\n\t\tif (window.location.href.indexOf('overlay') > -1) {\n\t\t\treturn false;\n\t\t}\n\n\t}\n\n\tif (sessionStorage.getItem('mobilePickupOrdering')==='seen') {\n\t\treturn false;\n\t}\n\n\treturn true;\n}\n\n//Standard modal\nwindow.pnraTarget.fn.addStandardModal = function(modalID, modTitle, modtext, modMainBtnCTA, modSecBtnCTA) {\n\t\tvar iwApp = document.querySelector('[iw-app]');\n\t\tvar vue;\n\t\t \n\t\tif (iwApp) {\n\t\t\tvar vue = iwApp.__vue__;\n\t\t}\n\n\t\t// Show modal\n\t\tif (vue && sessionStorage.getItem(modalID) != 'shown') {\n\t\t\tvue.$store.dispatch('uiState/showAlertWithData', {\n\t\t\t\toverlayId: modalID,\n\t\t\t\tdata: {\n\t\t\t\t\ttype: 'modal',\n\t\t\t\t\ttitleString: modTitle,\n\t\t\t\t\ttextString: modtext,\n\t\t\t\t\tmainButtonKey: 'snackbar.customMessage',\n\t\t\t\t\tmainButtonVariables: [modMainBtnCTA],\n\t\t\t\t\tsecondaryButtonKey: 'snackbar.customMessage',\n\t\t\t\t\tsecondaryButtonVariables: [modSecBtnCTA]\n\t\t\t\t},\n\t\t\t});\n\t\t\ttry { sessionStorage.setItem(modalID,'shown') } catch(e) { }\n\t\t}\n}\n\n//orderSetupDelivery\nwindow.pnraTarget.fn.orderSetupDelivery = function() {\n\tiwApp = document.querySelector('[iw-app]');\n\t$store = iwApp.__vue__.$store;\n\t$store.dispatch('uiState/showOverlay', {\n\t\toverlayId: 'order-setup-flow',\n\t\tdata: {\n\t\t\tdestination: 'DELIVERY',\n\t\t},\n\t});\n}\n\n//orderSetupRPU\nwindow.pnraTarget.fn.orderSetupRPU = function() {\n\tiwApp = document.querySelector('[iw-app]');\n\t$store = iwApp.__vue__.$store;\n\t$store.dispatch('uiState/showOverlay', {\n\t\toverlayId: 'order-setup-flow',\n\t\tdata: {\n\t\t},\n\t});\n}\n\n//get user's email address\nwindow.pnraTarget.fn.getUserEmailAddress = function(e){\n\ttry {\n\t\tiwApp = document.querySelector('[iw-app]');\n\t\t$store = iwApp.__vue__.$store;\n\t\tuserDetails = $store.getters['user/customerFromDetails'];\n\t\treturn userDetails.email || '';\n\t} catch(e) {\n\t\treturn '';\n\t}  \n};\n\n//get user's phone number\nwindow.pnraTarget.fn.getUserPhoneNumber = function(e){\n\ttry {\n\t\tiwApp = document.querySelector('[iw-app]');\n\t\t$store = iwApp.__vue__.$store;\n\t\tuserDetails = $store.getters['user/customerFromDetails'];\n\t\treturn userDetails.phone || '';\n\t} catch(e) {\n\t\treturn '';\n\t}  \n};\n\n//Upsell Drawer\nwindow.pnraTarget.fn.atUpsellDrawer = function(upsellType, direction) {\n\t// Show drawer\n\tvar iwApp = document.querySelector('[iw-app]');\n\tvar vue;\n\tvar Vue;\n\tif (iwApp) {\n\t\tvar vue = iwApp.__vue__;\n\t\tVue = iwApp.__vue__.$root._provided.$Vue;\n\t}\n\n\tif (vue) {\n\t\tvue.$store.dispatch('uiState/showOverlay', {\n\t\t\toverlayId: upsellType,\n\t\t\tdata: {\n\t\t\t\ttype: 'drawer',\n\t\t\t\t//component: 'test-component',\n\t\t\t\tedge: direction, // 'right', 'left', or 'bottom'\n\t\t\t\tcloseButton: true,\n\t\t\t\tcomponentAttr: {\n\t\t\t\t\t// Props to be bound\n\t\t\t\t\t//name: '780709',\n\t\t\t\t\t//productId: '123456',\n\t\t\t\t},\n\t\t\t\tcomponentListeners: {\n\t\t\t\t\t// Listeners to be bound\n\t\t\t\t\tctaClick: function() {\n\t\t\t\t\t\t//console.log('cta-click');\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t});\n\t}\n}\n\n//SignIn Overlay\nwindow.pnraTarget.fn.atSignInOverlay = function() {\n\t// Show drawer\n\tvar iwApp = document.querySelector('[iw-app]');\n\tvar vue;\n\tif (iwApp) {\n\t\tvue = iwApp.__vue__;\n\t}\n\n\tif (vue) {\n\t\tvue.$store.dispatch('uiState/showOverlay', {\n\t\t\toverlayId: 'sign-in',\n\t\t});\n\t}\n}\n\n//SignUp Overlay\nwindow.pnraTarget.fn.atSignUpOverlay = function() {\n\t// Show drawer\n\tvar iwApp = document.querySelector('[iw-app]');\n\tvar vue;\n\tif (iwApp) {\n\t\tvue = iwApp.__vue__;\n\t}\n\n\tif (vue) {\n\t\tvue.$store.dispatch('uiState/showOverlay', { \n\t\t\toverlayId: 'iw-join-my-panera-drawer', \n\t\t\tdata: { type: 'drawer', component: 'iw-join-my-panera-drawer', edge: 'right', closeButton: false, } \n\t\t})\n\t}\n}\n\n//OTP SignIn Drawer\nwindow.pnraTarget.fn.atOTPDrawer = function() {\n\t// Show drawer\n\tvar iwApp = document.querySelector('[iw-app]');\n\tvar vue;\n\tif (iwApp) {\n\t\tvue = iwApp.__vue__;\n\t}\n\n\tif (vue) {\n\t\tvue.$store.dispatch('uiState/showOverlay', {\n\t\t\toverlayId: 'otp-sign-in-flow',\n\t\t\tdata: {\n\t\t\t\ttype: 'drawer',\n\t\t\t\tcomponent: 'iw-otp-sign-in-flow',\n\t\t\t\thideOverlayActions: true,\n\t\t\t\tzIndex: 20,\n\t\t\t\tcontainerClasses: {\n\t\t\t\t\t'iw-drawer-content iw-drawer-right position-fixed': true,\n\t\t\t\t\t\n\t\t\t\t},\n\t\t\t\tedge: {\n\t\t\t\t\tmd: 'right',\n\t\t\t\t\tsm: 'right',\n\t\t\t\t\txs: 'bottom',\n\t\t\t\t},\n\t\t\t},\n\t\t  });\n\t}\n}\n\nwindow.pnraTarget.fn.cartHasBeverage = function() {\n\tif (atAllBeverageItems && atAllBeverageItems.length > 0 && dataLayer && dataLayer.cart && dataLayer.cart.products && dataLayer.cart.products.length > 0) {\n\t\tfor (var i=0; i<dataLayer.cart.products.length; i++) {\n\t\t\tif (atAllBeverageItems.includes(dataLayer.cart.products[i].itemId)) { return true }\n\t\t}\n\t}\n\treturn false;\n}\n\nwindow.pnraTarget.fn.waitForVariableOrElement = function(selector, experiment, timeout, keepAlive, interval) {\n  \n\t//Definitions:\n\t//\t\"selector\" - required - must be a string\n\t//\t\"experiment\" - required - is the function to run once the selector exists and/or returns not false\n\t//\t\"timeout\" - optional - default is 3 seconds - is how long this function should continue polling for the selector \n\t//\t\"keepAlive\" - optional - default is true - set to false if you want this to evaluate only one time\n\t//\t\"interval\" - optional - default is 500ms - sets how frequently this function runs while still alive\n\n\t//Usage Examples:\n\t//\tWait for an element with a specific ID, check every half second for no more than 3 seconds\n\t//\t\twindow.pnraTarget.fn.waitForVariableOrElement(\"document.querySelector('[id=\\\"atPromoModal\\\"]')\",functionToRun,3000,true,500)\n\t//\tWait for a variable to exist\n\t//\t\twindow.pnraTarget.fn.waitForVariableOrElement(\"dataLayer.user.customerId\",functionToRun)\n\t//\tWait for a variable to exist with a specific value\n\t//\t\twindow.pnraTarget.fn.waitForVariableOrElement(\"dataLayer.cafe.id==='123456'\",functionToRun)\n\t//\tWait for a variable to exist and be non-empty\n\t//\t\twindow.pnraTarget.fn.waitForVariableOrElement(\"dataLayer.user.customerId !=''\",functionToRun)\n\n\tvar intervalTime = 500;\n\tvar timeout = timeout || 3000;\n\tvar keepAlive = keepAlive || false;\n\tvar maxAttempts = timeout / intervalTime;\n\tvar attempts = 0;\n\tvar interval = setInterval(function() {\n\t\tvar selectorVal = (function(){\n\t\t\ttry {\n\t\t\t\treturn eval(selector);\n\t\t\t} catch(e) {\n\t\t\t\treturn undefined;\n\t\t\t}\n\t\t})();\n\t\tif (typeof selectorVal !== 'undefined' && selectorVal !== '' && selectorVal != false && selectorVal !== null) {\n\t\t\t//selector exists\n\t\t\tif (!keepAlive) {\n\t\t\t\tclearInterval(interval);\n\t\t\t}\n\t\t\texperiment();\n\t\t} else if (attempts > maxAttempts) {\n\t\t\t//console.log('maxAtempts reached');\n\t\t\tclearInterval(interval);\n\t\t}\n\t\tattempts ++;\n\t}, intervalTime);\n}\n\n\nwindow.pnraTarget.fn.accountHasReward = function(theReward) {\n\ttheReward = theReward.toString();\n\ttry {\n\t\tfor (var i=0; i<dataLayer.user.rewards.length; i++) {\n\t\t\tif (dataLayer.user.rewards[i].promoCode.toString() === theReward) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t} catch(e) {}\n\ttry {\n\t\tfor (var i=0; i<dataLayer.user.rewards.length; i++) {\n\t\t\tif (dataLayer.user.rewards[i].promoCode.toString() === theReward) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t} catch(e) {}\n\ttry {\n\t\tfor (var i=0; i<dataLayer.user.rewards.length; i++) {\n\t\t\tif (dataLayer.user.rewards[i].discCode.toString() === theReward) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t} catch(e) {}\n\treturn false;\n}\n\nwindow.pnraTarget.fn.cartHasDiscount = function(theDiscount) {\n\ttheDiscount = theDiscount.toString();\n\ttry {\n\t\tfor (var i=0; i<dataLayer.cart.discounts.length; i++) {\n\t\t\tif (dataLayer.cart.discounts[i].promoCode === theDiscount) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t} catch(e) {}\n\ttry {\n\t\tfor (var i=0; i<dataLayer.cart.discounts.length; i++) {\n\t\t\tif (dataLayer.cart.discounts[i].discCode === theDiscount) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t} catch(e) {}\n\n\treturn false;\n}\n\n\nwindow.pnraTarget.fn.redirectAfterMyPRegistration = function(goHere, redirectToHere) {\n\tif (redirectToHere) {\n\t\twindow.sessionStorage.redirectAfterMyPRegistration = redirectToHere;\n\t}\n\n\tif (goHere) {\n\t\twindow.location=goHere;\n\t}\n}\n\nwindow.pnraTarget.fn.isCompanyCafe = function(){\n\ttry {\n\t\t//if cart is not empty, can get it from digitalData\n\t\tif (dataLayer && dataLayer.cafe && dataLayer.cafe.id > 599999) {\n\t\t\treturn true\n\t\t}\n\n\t//backup place - we can try looking in sessionStorage\n\t\tvueData = JSON.parse(sessionStorage.getItem('vuex'));\n\t\tif (vueData.cart.cartObject.cafes[0].id > 599999) {\n\t\t\treturn true\n\t\t}\n\t\t\n\t\t//not found\n\t\treturn false\n\t} catch(e) { }\n\treturn false;\n}\n\nwindow.pnraTarget.fn.cartHasMIASD = function() {\n\ttry {\n\t\tvueData = JSON.parse(sessionStorage.getItem('vuex'));\n\t\tfor (var i=0; i<vueData.cart.dynamicPricingOverrides.eligibleOffers.length;i++) {\n\t\t\tif (vueData.cart.dynamicPricingOverrides.eligibleOffers[i].savingsCode === 'MIASD') {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t}\n\t\treturn false;\n\t} catch(e) {\n\t\treturn false;\n\t}\n}\n\nwindow.pnraTarget.fn.pageName = function() {\n\ttry {\n\t\tpageArr = window.location.pathname.split('/');\n\t\tpageHTML = pageArr[pageArr.length-1];\n\t\tpageName = pageHTML.split('.')[0];\n\t} catch(e) {\n\t\tpageName = '';\n\t}\n\n\t//page name modifications:\n\tif (pageName == 'applecard' && window.location.href.indexOf('/subscription/applecard') > 0) { pageName = 'subscription-applecard' }\n\tif (document.querySelectorAll('.pds-cart-details').length > 0) { pageName = 'cart' }\n\tif (document.querySelectorAll('.iw-drawer #checkout-drawer').length > 0) { pageName = 'Checkout_Drawer' }\n\t//if (document.querySelectorAll('.iw-drawer #checkout-drawer .iw-checkout-payment-v2').length > 0) { pageName = 'checkout payment info' }\n\n\treturn pageName;\n}\n\npnraTarget.fn.setEgiftPrice = function(price) {\n\tvar egiftDrawerElement = document.querySelector('[overlay-id=\"egift-card-drawer\"]');\n\tvar egiftDrawerComponent = egiftDrawerElement && egiftDrawerElement.__vue__;\n\tif (egiftDrawerComponent) {\n\t\tegiftDrawerComponent.price = price;\n\t}\n}\n\npnraTarget.fn.orderMenuType = function(lookupType){\n\t\tif (dataLayer && dataLayer.cart && dataLayer.cart.summary && dataLayer.cart.summary.orderFulfillmentConverted && dataLayer.cart.summary.orderFulfillmentConverted != '') {\n\t\t\t//orderFulfillmentConverted exists\n\t\t\tvar orderTime = new Date(dataLayer.cart.summary.orderFulfillmentConverted)\n\t\t\tvar orderTimeHours = orderTime.getHours();\n\t\t\tvar orderTimeMinutes = orderTime.getMinutes();\n\n\t\t\tif (orderTimeHours >= 11 ) { return 'PM' }\n\t\t\tif (orderTimeHours == 10 && orderTimeMinutes >=30 ) { return 'PM' }\n\t\t\treturn 'AM'\n\t\t}\n\n\treturn '';\n}\n\npnraTarget.fn.dayOfYear = function(date) {\n\tmsAgo = (date - new Date(date.getFullYear(), 0, 0))\n\tmsInADay = 86400000\n\treturn Math.floor(msAgo / msInADay);\n}\n\npnraTarget.fn.homepageCTA = function(element) {\n\t//console.log('javascript:pnraTarget.fn.homepageCTA()')\n\t//console.log('element=',element)\n\tif (element.closest('.swiper-slide')) {\n\t\tvar clickAttribute =  (function(){\n\t\t\ttry {\n\t\t\t\ttitle = element.getAttribute('title') || elemen
source:"// Function to check if elements exists before triggering a view change\n(function(win) {\n  'use strict';\n\n  var listeners = [],\n    doc = win.document,\n    MutationObserver = win.MutationObserver || win.WebKitMutationObserver,\n    tgtObserver;\n\n  function tgtReady(selector, fn) {\n    listeners.push({\n      selector: selector,\n      fn: fn\n    });\n    if (!tgtObserver) {\n      tgtObserver = new MutationObserver(check);\n      tgtObserver.observe(doc.documentElement, {\n        childList: true,\n        subtree: true\n      });\n    }\n    check();\n  }\n\n  function check() {\n    for (var i = 0, len = listeners.length, listener, elements; i < len; i++) {\n      listener = listeners[i];\n      elements = doc.querySelectorAll(listener.selector);\n      for (var j = 0, jLen = elements.length, element; j < jLen; j++) {\n        // Override j to 0 for first match only\n        element = elements[j];\n        if (!element.tgtReady) {\n          element.tgtReady = true;\n          listener.fn.call(element, element);\n        }\n      }\n    }\n  }\n  win.tgtReady = tgtReady;\n})(this);\n\n\n// Do something when selector is matched, like re-render the Target view\n// Make sure to only use very specific selectors that are unique for when you want to re-render a view\n// Use \"page: false\" if you want to reprocess the view without incrementing an impression in Target\n\n//Order SetupFlow Overlay\n// NOTE: Disabled for debugging A4T, the .order-setup-flow selector is available immediately on any page load.\n// This should be adjusted to fire only when the overlay actually becomes visible\n/*\ntgtReady('.order-setup-flow', function(element) {\n  adobe.target.triggerView(_satellite.getVar(\"target: view name\"), {page: true});\n  _satellite.logger.log(\"AT: Re-rendering view... order-setup-flow\");  \n});\n*/\n\n//Used for Adobe Recommendations (Upsells)\ntgtReady('.iw-drawer aside', function(element) {\n\tvar viewName = element.id;\n\tadobe.target.triggerView(viewName, {page: true});\n});\n\ntgtReady('#cart-drawer', function(element) {\n\tvar viewName = element.id;\n\tadobe.target.triggerView(viewName, {page: true});\n});\n\ntgtReady('.iw-drawer aside .yumyums-complete', function(element) {\n\tvar viewName = element.closest('aside').id;\n\t//console.log('viewName',viewName);\n\t_satellite.track('adobe upsell drawer',{ boxName: viewName} ); \n});\n\ntgtReady('.iw-drawer aside .iw-upsell-drawer', function(element) {\n\tvar viewName = element.getAttribute('name');\n\t//console.log('viewName',viewName);\n\t_satellite.track('adobe upsell drawer',{ boxName: viewName} ); \n});\n\n\n// ttMETA plugin for response tokens\ndocument.addEventListener(adobe.target.event.REQUEST_SUCCEEDED, function(e) {\n  window.ttMETA = typeof(window.ttMETA) != \"undefined\" ? window.ttMETA : [];\n  var tokens = e.detail.responseTokens;\n  if (isEmpty(tokens)) {\n    return;\n  }\n  var uniqueTokens = distinct(tokens);\n  uniqueTokens.forEach(function(token) {\n    window.ttMETA.push({\n      'activityName': token[\"activity.name\"],\n      'activityId': token[\"activity.id\"],\n      'experienceName': token[\"experience.name\"],\n      'experienceId': token[\"experience.id\"]\n      // 'OfferId': token[\"offer.id\"],\n      // 'OfferName': token[\"offer.name\"],\n      // 'OptionId': token[\"option.id\"],\n      // 'OptionName': token[\"option.name\"]\n    });\n  });\n});\n\n//pnraTarget.ATExperienceList response tokens\ndocument.addEventListener(adobe.target.event.REQUEST_SUCCEEDED, function(e) {\n\tif (e.detail.responseTokens) {\n\t\tvar rt = e.detail.responseTokens;\n\t\twindow.pnraTarget = pnraTarget || {};\n\t\tpnraTarget.arrUniqueActExp = pnraTarget.arrUniqueActExp || []\n\t\tpnraTarget.ATExperienceList = pnraTarget.ATExperienceList || [];\n\t\tfor (var i=0; i<rt.length; i++) {\n\t\t\tvar inList = false;\n\t\t\tfor (var j=0; j<pnraTarget.arrUniqueActExp.length; j++) {\xa0\xa0\xa0\xa0\xa0\xa0\xa0\xa0\xa0\xa0\n\t\t\t\tif (pnraTarget.arrUniqueActExp[j] == rt[i]['activity.id']+':'+rt[i]['experience.id']) {\n\t\t\t\t\tinList = true;\n\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}\n\t\t\tif (!inList && typeof rt[i]['activity.id'] === 'string') {\n\t\t\t\t//console.log(rt[i]);\n\t\t\t\tpnraTarget.arrUniqueActExp.push(rt[i]['activity.id']+':'+rt[i]['experience.id']); //so we don't add it again\n\t\t\t\tpnraTarget.ATExperienceList.push({\n\t\t\t\t\tcampaignName: rt[i]['activity.name'],\n\t\t\t\t\texperienceName: rt[i]['experience.name'] ,\n\t\t\t\t\tcampaignId: rt[i]['activity.id'],\n\t\t\t\t\texperienceId: rt[i]['experience.id'],\n\t\t\t\t\tallocationType: rt[i]['experience.trafficAllocationType'] || 'non-automated'\n\t\t\t\t});\n\t\t\t\tconsole.log(\"You are in \" + rt[i]['activity.name']+':'+rt[i]['experience.name'] + \".\");\n\n\t\t\t}\n\t\t\t\n\t\t\t\n\t\t\t//place zipcode into window scpoed variable\n\t\t\tif (rt[i]['geo.zip'] && rt[i]['geo.zip'] != '') { pnraTarget.zipCode = rt[i]['geo.zip'] }\n\t\t\tif (rt[i]['geo.country'] && rt[i]['geo.country'] != '') { pnraTarget.country = rt[i]['geo.country'] }\n\t\t}\n\t}\n});\n\n\nfunction isEmpty(val) {\n  return (val === undefined || val == null || val.length <= 0) ? true : false;\n}\n\nfunction key(obj) {\n  return Object.keys(obj)\n    .map(function(k) {\n      return k + \"\" + obj[k];\n    })\n    .join(\"\");\n}\n\nfunction distinct(arr) {\n  var result = arr.reduce(function(acc, e) {\n    acc[key(e)] = e;\n    return acc;\n  }, {});\n  return Object.keys(result)\n    .map(function(k) {\n      return result[k];\n    });\n}",language:"javascript"}},{modulePath:"adobe-target-v2/lib/addParams.js",settings:{params:{at_property:{value:"%AT: property token%",checked:!0},"profile.loggedIn":{value:"%loggedIn (cookie:ssoToken)%",checked:!0},"profile.localTime":{value:"%local time%",checked:!0},"profile.loginType":{value:"%loginType%",checked:!0},"profile.lastCafeId":{value:"%cafe: id (non-national)%",checked:!0}}}},{modulePath:"core/src/lib/actions/customCode.js",settings:{source:'const uniqueId = () => {\n  const dateString = Date.now().toString(36);\n  const randomness = Math.random().toString(36).substr(2);\n  return dateString + randomness;\n};\n\nadobe.target.getOffers({\n  consumerId: uniqueId(),\n  request: {\n    "execute":{\n      "pageLoad":{}\n    },\n    "prefetch": {\n      "views": [{}]\n    }\n  }\n}).then(function(response) {\n  adobe.target.applyOffers({\n    response: response\n  })\n}).then(function() {\n  adobe.target.triggerView(_satellite.getVar("target: view name"), {page: true});\n  _satellite.logger.log("AT: Rendering view... " + _satellite.getVar("target: view name"));\n  _satellite.track("target-complete");\n\n}).catch(function(error) {\n  adobe.target.triggerView(_satellite.getVar("target: view name"), {page: true});\n  _satellite.logger.log("AT: Target may be disabled, triggering view for VEC... " + _satellite.getVar("target: view name"));\n  _satellite.track("target-complete");\n  console.log("Error", error);\n});',language:"javascript"}}]},{id:"RLfc6081328e9c4efb8fd97da557ab2209",name:"Landing Page | Start My Subscription Button | CoreClick - .iw-subscription-v2-subscribe silo-button | [3PT, Reddit, Snapchat, TikTok, Twitter]",events:[{modulePath:"core/src/lib/events/click.js",settings:{elementSelector:".iw-subscription-v2-subscribe silo-button",bubbleFireIfParent:!0,bubbleFireIfChildFired:!0},ruleOrder:50}],conditions:[{modulePath:"core/src/lib/conditions/customCode.js",settings:{source:function(){return"allowDataShare"===_satellite.getVar("allowDataShare")&&window===window.parent}}}],actions:[{modulePath:"core/src/lib/actions/customCode.js",settings:{source:"https://assets.adobedtm.com/28c384412a45/1990dac605a3/58a55f889841/RC753bd983150b411aafe260dcc6d3c374-source.min.js",language:"javascript",isExternal:!0}},{modulePath:"core/src/lib/actions/customCode.js",settings:{source:"https://assets.adobedtm.com/28c384412a45/1990dac605a3/58a55f889841/RC118a44a159704b7c80e8f732daa4b58f-source.min.js",language
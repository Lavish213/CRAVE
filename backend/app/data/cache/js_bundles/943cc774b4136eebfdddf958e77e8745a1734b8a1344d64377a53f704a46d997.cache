 'value-constr-yp2-tier-sub-prem',\n\t\t\t  'value-constr-yp2-value-menu',\n\t\t\t];\n\t\tconst cafeHasYP2Modal = cafeFeatures.some((feature) => yp2CafeFeatureFlags.includes(feature)) || false;\n\t\t\n\t\treturn cafeHasYP2Modal && isYp2PostOrderSetupModalEnabled\n\t} catch(e) {}\n}\n",language:"javascript"}}]},{id:"RLf406e9de16664e06947c035da6155732",name:"AA:Overlay-30:Cart:Alert-Redeem Rewards Invalid",events:[{modulePath:"core/src/lib/events/entersViewport.js",settings:{elementSelector:"#redeem-rewards-invalid"},ruleOrder:30}],conditions:[],actions:[{modulePath:"adobe-analytics/src/lib/actions/setVariables.js",settings:{customSetup:{source:function(e,t){var a=t.pageName,r=_satellite.getVar("content: language");t.eVar14=a,t.eVar1="/"+r+"/ecommerce/cart/alert/reward-redeemed-invalid",t.eVar1=t.eVar1.toLowerCase(),t.eVar2=t.eVar1.split("/")[2],t.eVar3=t.eVar1.split("/")[3],t.eVar4=t.eVar1.split("/")[4],t.events="",t.pageName=t.eVar1,t.products="",t.campaign="",t.eVar5="",t.eVar6=t.eVar2+"-alert",t.eVar15="",t.eVar16="",t.eVar17="",t.eVar18="",t.eVar19="",t.eVar20="",t.eVar31="",t.eVar32="",t.eVar33="",t.eVar34="",t.eVar35="",t.eVar36="",t.eVar37="",t.eVar38="",t.eVar41="",t.eVar42="",t.eVar43="",t.eVar44="",t.eVar45="",_satellite.setVar("pgType","click")}},trackerProperties:{}}},{modulePath:"adobe-analytics/src/lib/actions/sendBeacon.js",settings:{type:"page"}}]},{id:"RLf63bbbaee39c451f9c7e9678de8f3b49",name:"AA:Overlay-30:Sign-Up-Light",events:[{modulePath:"core/src/lib/events/entersViewport.js",settings:{elementSelector:"#lite-reg-overlay"},ruleOrder:30}],conditions:[],actions:[{modulePath:"adobe-analytics/src/lib/actions/setVariables.js",settings:{customSetup:{source:function(e,t){var a=t.pageName,r=_satellite.getVar("content: language");t.eVar14=a,t.eVar1="/"+r+"/mypanera/sign-up-with-mypanera/lite",t.eVar1=t.eVar1.toLowerCase(),t.eVar2=t.eVar1.split("/")[2],t.eVar3=t.eVar1.split("/")[3],t.eVar4=t.eVar1.split("/")[4],t.events="event21",t.pageName=t.eVar1,t.produ